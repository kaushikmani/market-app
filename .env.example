# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── API Keys ───────────────────────────────────────────────────────────────────
# Polygon.io — real-time & historical market data
# Get yours free at: https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Google Gemini — AI-powered analysis, earnings previews & news sentiment
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Browser Profile ────────────────────────────────────────────────────────────
# Optional: custom path for the Playwright browser profile (for X/Twitter login)
# Defaults to ~/.stock-analyzer/browser-profile
# BROWSER_PROFILE_DIR=/custom/path/to/browser-profile
